{
  "uid": "service-overview",
  "title": "Service Overview",
  "description": "RED metrics (Rate, Errors, Duration) for all NewsAnalyzer services",
  "tags": ["observability", "newsanalyzer"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "templating": {
    "list": [
      {
        "name": "environment",
        "type": "custom",
        "label": "Environment",
        "current": {
          "selected": true,
          "text": "dev",
          "value": "dev"
        },
        "options": [
          { "selected": true, "text": "dev", "value": "dev" },
          { "selected": false, "text": "prod", "value": "prod" }
        ],
        "query": "dev,prod"
      },
      {
        "name": "service",
        "type": "custom",
        "label": "Service",
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "options": [
          { "selected": true, "text": "All", "value": "$__all" },
          { "selected": false, "text": "newsanalyzer-backend", "value": "newsanalyzer-backend" },
          { "selected": false, "text": "newsanalyzer-frontend", "value": "newsanalyzer-frontend" },
          { "selected": false, "text": "newsanalyzer-reasoning", "value": "newsanalyzer-reasoning" }
        ],
        "query": "newsanalyzer-backend,newsanalyzer-frontend,newsanalyzer-reasoning"
      }
    ]
  },
  "links": [
    {
      "title": "Backend JVM",
      "type": "link",
      "icon": "external link",
      "url": "/d/backend-jvm",
      "tooltip": "JVM runtime metrics"
    },
    {
      "title": "Reasoning Service",
      "type": "link",
      "icon": "external link",
      "url": "/d/reasoning-service",
      "tooltip": "Python service metrics"
    },
    {
      "title": "Distributed Traces",
      "type": "link",
      "icon": "external link",
      "url": "/d/distributed-traces",
      "tooltip": "Tempo trace search"
    },
    {
      "title": "Log Explorer",
      "type": "link",
      "icon": "external link",
      "url": "/d/log-explorer",
      "tooltip": "Loki log exploration"
    }
  ],
  "panels": [
    {
      "id": 1,
      "title": "Request Rate",
      "description": "HTTP requests per second by service (5m rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false,
            "axisBorderShow": false,
            "axisCenteredZero": false
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (service_name) (rate(http_server_request_duration_seconds_count{deployment_environment=~\"$environment\", service_name=~\"$service\"}[5m]))",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate",
      "description": "Percentage of HTTP 5xx responses by service (5m window)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (service_name) (rate(http_server_request_duration_seconds_count{deployment_environment=~\"$environment\", service_name=~\"$service\", http_response_status_code=~\"5..\"}[5m])) / sum by (service_name) (rate(http_server_request_duration_seconds_count{deployment_environment=~\"$environment\", service_name=~\"$service\"}[5m]))",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Request Latency (P95)",
      "description": "95th percentile request duration by service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(http_server_request_duration_seconds_bucket{deployment_environment=~\"$environment\", service_name=~\"$service\"}[5m])))",
          "legendFormat": "p95 {{service_name}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Request Latency Percentiles",
      "description": "P50, P95, P99 request duration across all selected services",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "P50",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (le, service_name) (rate(http_server_request_duration_seconds_bucket{deployment_environment=~\"$environment\", service_name=~\"$service\"}[5m])))",
          "legendFormat": "p50 {{service_name}}"
        },
        {
          "refId": "P95",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(http_server_request_duration_seconds_bucket{deployment_environment=~\"$environment\", service_name=~\"$service\"}[5m])))",
          "legendFormat": "p95 {{service_name}}"
        },
        {
          "refId": "P99",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le, service_name) (rate(http_server_request_duration_seconds_bucket{deployment_environment=~\"$environment\", service_name=~\"$service\"}[5m])))",
          "legendFormat": "p99 {{service_name}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Request Rate by Service",
      "description": "Current request rate per service",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 0.1 },
              { "color": "yellow", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "area",
        "colorMode": "background",
        "textMode": "auto",
        "orientation": "horizontal"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (service_name) (rate(http_server_request_duration_seconds_count{deployment_environment=~\"$environment\", service_name=~\"$service\"}[5m]))",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Web Vitals — LCP",
      "description": "Largest Contentful Paint — measures loading performance. Good: <2.5s, Needs Improvement: <4s, Poor: >4s",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "ms",
          "min": 0,
          "max": 6000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2500 },
              { "color": "red", "value": 4000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "web_vitals_lcp{deployment_environment=~\"$environment\"}",
          "legendFormat": "LCP"
        }
      ]
    },
    {
      "id": 7,
      "title": "Web Vitals — CLS",
      "description": "Cumulative Layout Shift — measures visual stability. Good: <0.1, Needs Improvement: <0.25, Poor: >0.25",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "none",
          "min": 0,
          "max": 0.5,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.25 }
            ]
          },
          "decimals": 3
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "web_vitals_cls{deployment_environment=~\"$environment\"}",
          "legendFormat": "CLS"
        }
      ]
    },
    {
      "id": 8,
      "title": "Web Vitals — INP",
      "description": "Interaction to Next Paint — measures responsiveness. Good: <200ms, Needs Improvement: <500ms, Poor: >500ms",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "ms",
          "min": 0,
          "max": 1000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "web_vitals_inp{deployment_environment=~\"$environment\"}",
          "legendFormat": "INP"
        }
      ]
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
