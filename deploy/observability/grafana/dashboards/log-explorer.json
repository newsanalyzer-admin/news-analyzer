{
  "uid": "log-explorer",
  "title": "Log Explorer",
  "description": "Centralized log exploration with service filtering and trace ID correlation",
  "tags": ["observability", "newsanalyzer", "logs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "custom",
        "label": "Service",
        "current": {
          "selected": true,
          "text": "All",
          "value": "newsanalyzer-.+"
        },
        "options": [
          { "selected": true, "text": "All", "value": "newsanalyzer-.+" },
          { "selected": false, "text": "Backend", "value": "newsanalyzer-backend" },
          { "selected": false, "text": "Frontend", "value": "newsanalyzer-frontend" },
          { "selected": false, "text": "Reasoning", "value": "newsanalyzer-reasoning" }
        ],
        "query": "newsanalyzer-.+,newsanalyzer-backend,newsanalyzer-frontend,newsanalyzer-reasoning"
      },
      {
        "name": "level",
        "type": "custom",
        "label": "Log Level",
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "options": [
          { "selected": true, "text": "All", "value": "$__all" },
          { "selected": false, "text": "ERROR", "value": "ERROR" },
          { "selected": false, "text": "WARN", "value": "WARN" },
          { "selected": false, "text": "INFO", "value": "INFO" },
          { "selected": false, "text": "DEBUG", "value": "DEBUG" }
        ],
        "query": "ERROR,WARN,INFO,DEBUG"
      },
      {
        "name": "search",
        "type": "textbox",
        "label": "Search",
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        }
      }
    ]
  },
  "links": [
    {
      "title": "Service Overview",
      "type": "link",
      "icon": "external link",
      "url": "/d/service-overview",
      "tooltip": "RED metrics for all services"
    },
    {
      "title": "Distributed Traces",
      "type": "link",
      "icon": "external link",
      "url": "/d/distributed-traces",
      "tooltip": "Tempo trace search"
    }
  ],
  "panels": [
    {
      "id": 1,
      "title": "Log Volume",
      "description": "Log line count over time by detected level",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "ERROR" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "WARN" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }]
          },
          {
            "matcher": { "id": "byName", "options": "INFO" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "DEBUG" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (detected_level) (count_over_time({service_name=~\"$service\"} [1m]))",
          "legendFormat": "{{detected_level}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Logs",
      "description": "Log stream — trace IDs are clickable links to Tempo (via Loki derived fields). Use the Service and Log Level dropdowns to filter.",
      "type": "logs",
      "gridPos": { "h": 18, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service_name=~\"$service\"} |~ \"(?i)$level\" |~ \"$search\"",
          "legendFormat": ""
        }
      ]
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
